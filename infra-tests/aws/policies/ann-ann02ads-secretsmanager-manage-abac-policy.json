{
    "Statement": [
        {
            "Action": [
                "secretsmanager:*"
            ],
            "Condition": {
                "ForAllValues:StringEquals": {
                    "aws:TagKeys": [
                        "access-project",
                        "access-team",
                        "Project",
                        "Name",
                        "RedshiftDataFullAccess"
                    ]
                },
                "StringEquals": {
                    "aws:RequestTag/access-project": "${aws:PrincipalTag/access-project}",
                    "aws:RequestTag/access-team": "${aws:PrincipalTag/access-team}",
                    "aws:ResourceTag/access-project": "${aws:PrincipalTag/access-project}",
                    "aws:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                },
                "StringLike": {
                    "aws:RequestTag/Project": [
                        "?*"
                    ]
                },
                "StringLikeIfExists": {
                    "aws:RequestTag/Name": [
                        "*"
                    ],
                    "aws:RequestTag/RedshiftDataFullAccess": [
                        "*"
                    ]
                }
            },
            "Effect": "Allow",
            "Resource": [
                "*"
            ],
            "Sid": "PermissionPolicyToRequireAttributesOnNewResources"
        },
        {
            "Action": [
                "secretsmanager:GetRandomPassword",
                "secretsmanager:ListSecrets"
            ],
            "Effect": "Allow",
            "Resource": "*"
        },
        {
            "Action": [
                "secretsmanager:Describe*",
                "secretsmanager:List*"
            ],
            "Condition": {
                "StringEquals": {
                    "secretsmanager:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "ReadSecretsManagerSameTeam"
        },
        {
            "Action": [
                "secretsmanager:Get*"
            ],
            "Condition": {
                "ForAnyValue:StringEquals": {
                    "secretsmanager:VersionStage": "AWSCURRENT"
                },
                "StringEquals": {
                    "secretsmanager:ResourceTag/access-project": "${aws:PrincipalTag/access-project}",
                    "secretsmanager:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                }
            },
            "Effect": "Allow",
            "Resource": "*"
        },
        {
            "Action": [
                "secretsmanager:TagResource"
            ],
            "Condition": {
                "ForAllValues:StringEquals": {
                    "aws:TagKeys": [
                        "Project",
                        "Name",
                        "RedshiftDataFullAccess"
                    ]
                },
                "StringEquals": {
                    "aws:ResourceTag/access-project": "${aws:PrincipalTag/access-project}",
                    "aws:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                },
                "StringLikeIfExists": {
                    "aws:RequestTag/Name": [
                        "*"
                    ],
                    "aws:RequestTag/Project": [
                        "*"
                    ],
                    "aws:RequestTag/RedshiftDataFullAccess": [
                        "*"
                    ]
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "PermissionPolicyToManageTags"
        },
        {
            "Action": "secretsmanager:*Policy",
            "Effect": "Deny",
            "Resource": "*"
        },
        {
            "Action": [
                "secretsmanager:UnTagResource"
            ],
            "Condition": {
                "ForAnyValue:StringLike": {
                    "aws:TagKeys": [
                        "access-*",
                        "Project"
                    ]
                }
            },
            "Effect": "Deny",
            "Resource": "*"
        }
    ],
    "Version": "2012-10-17"
}