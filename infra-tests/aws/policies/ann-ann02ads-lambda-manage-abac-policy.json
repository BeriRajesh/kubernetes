{
    "Statement": [
        {
            "Action": [
                "lambda:CreateFunction"
            ],
            "Condition": {
                "ForAllValues:StringEquals": {
                    "aws:TagKeys": [
                        "access-project",
                        "access-team",
                        "Name"
                    ]
                },
                "ForAnyValue:StringEquals": {
                    "aws:TagKeys": [
                        "access-project",
                        "access-team",
                        "Name",
                        "Authorizers",
                        "Environment",
                        "Hyperion",
                        "Application",
                        "ServiceGroup",
                        "tower",
                        "monitoring",
                        "Approver",
                        "Client",
                        "Compliance",
                        "Job Code",
                        "Location",
                        "OS",
                        "Patch Group",
                        "Project",
                        "Owner",
                        "Protection Tier",
                        "Roll up",
                        "Scope",
                        "Service Hours",
                        "Data Classification",
                        "Placement",
                        "Data Retention",
                        "ManagedBy"
                    ]
                },
                "StringEquals": {
                    "aws:RequestTag/access-team": "${aws:PrincipalTag/access-team}"
                },
                "StringLikeIfExists": {
                    "aws:RequestTag/Name": "*",
                    "aws:RequestTag/access-project": [
                        "${aws:PrincipalTag/access-project}"
                    ],
                    "aws:RequestTag/access-team": [
                        "${aws:PrincipalTag/access-team}"
                    ]
                }
            },
            "Effect": "Allow",
            "Resource": [
                "*"
            ],
            "Sid": "PermissionPolicyToRequireAttributesOnNewResources"
        },
        {
            "Action": [
                "lambda:CreateAlias",
                "lambda:CreateCodeSigningConfig",
                "lambda:CreateEventSourceMapping",

                "lambda:DeleteAlias",
                "lambda:DeleteCodeSigningConfig",
                "lambda:DeleteFunction",
                "lambda:DeleteFunctionConcurrency",
                "lambda:DeleteFunctionEventInvokeConfig",
                "lambda:DeleteProvisionesConcurrencyConfig",
                "lambda:DeleteLayerVersion",

                "lambda:Invoke",
                "lambda:InvokeAsync",
                "lambda:PublishLayerVersion",

                "lambda:PutFunctionCodeSigningConfig",
                "lambda:PutFunctionConcurrency",
                "lambda:PutFunctionEventInvokeConfig",
                "lambda:PutProvisionedConcurrencyConfig",

                "lambda:RemoveLayerVersionPermission",
                "lambda:RemovePermissions",

                "lambda:UpdateAlias",
                "lambda:UpdateCodeSigningConfig",
                "lambda:UpdateEventSourceMapping",
                "lambda:UpdateFunctionCode",
                "lambda:UpdateFunctionConfiguration",
                "lambda:UpdateFunctionEventInvokeConfig"
            ],
            "Condition": {
                "StringEquals": {
                    "secretsmanager:ResourceTag/access-project": "${aws:PrincipalTag/access-project}",
                    "secretsmanager:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "AllActionsSecretsManagerSameProjectSameTeam"
        },
        {
            "Action": [
                "lambda:List*"
            ],
            "Condition": {
                "StringEquals": {
                    "secretsmanager:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "ReadSecretsManagerSameTeam"
        },
        {
            "Action": [
                "lambda:Get*"
            ],
            "Condition": {
                "StringEquals": {
                    "secretsmanager:ResourceTag/access-project": "${aws:PrincipalTag/access-project}",
                    "secretsmanager:ResourceTag/access-team": "${aws:PrincipalTag/access-team}"
                }
            },
            "Effect": "Allow",
            "Resource": "*"
        },
        {
            "Action": [
                "lambda:TagResource"
            ],
            "Condition": {
                "ForAnyValue:StringEquals": {
                    "aws:TagKeys": [
                        "access-project",
                        "access-team",
                        "Name",
                        "Authorizers",
                        "Environment",
                        "Hyperion",
                        "Application",
                        "ServiceGroup",
                        "tower",
                        "monitoring",
                        "Approver",
                        "Client",
                        "Compliance",
                        "Job Code",
                        "Location",
                        "OS",
                        "Patch Group",
                        "Project",
                        "Owner",
                        "Protection Tier",
                        "Roll up",
                        "Scope",
                        "Service Hours",
                        "Data Classification",
                        "Placement",
                        "Data Retention",
                        "ManagedBy"
                    ]
                },
                "StringEquals": {
                    "aws:ResourceTag/access-project": [
                        "${aws:PrincipalTag/access-project}"
                    ],
                    "aws:ResourceTag/access-team": [
                        "${aws:PrincipalTag/access-team}"
                    ]
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "PermissionPolicyToManageTags"
        },
        {
            "Action": [
                "lambda:UntagResource"
            ],
            "Condition": {
                "StringEquals": {
                    "aws:ResourceTag/access-project": [
                        "${aws:PrincipalTag/access-project}"
                    ],
                    "aws:ResourceTag/access-team": [
                        "${aws:PrincipalTag/access-team}"
                    ],
                    "aws:RequestedRegion": [
                        "us-east-1"
                    ]
                }
            },
            "Effect": "Allow",
            "Resource": "*",
            "Sid": "PermissionPolicyToManageUntags"
        },
        {
            "Action": [
                "lambda:UntagResource"
            ],
            "Condition": {
                "StringLike": {
                    "aws:TagKeys": [
                        "access-*"
                    ]
                }
            },
            "Effect": "Deny",
            "Resource": "*",
            "Sid": "DenyUntagSecretsManagerReservedTags"
        }
    ],
    "Version": "2012-10-17"
}