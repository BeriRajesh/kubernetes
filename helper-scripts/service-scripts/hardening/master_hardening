#07
#Change default shell
echo "Changing Default shell....."
pass="/etc/passwd"
sudo chmod 666 $pass
sudo sed -i 's/daemon:x:1:1:daemon:\/usr\/sbin:\/bin\/sh/daemon:x:1:1:daemon:\/usr\/sbin:\/dev\/null/' $pass
sudo sed -i 's/bin:x:2:2:bin:\/bin:\/bin\/sh/bin:x:2:2:bin:\/bin:\/dev\/null/' $pass
sudo sed -i 's/nobody:x:65534:65534:nobody:\/nonexistent:\/bin\/sh/nobody:x:65534:65534:nobody:\/nonexistent:\/dev\/null/' $pass
echo "Default shell has been changed....."
sudo chmod 644 $pass
echo "**********************************************"


