#Installing essential pkgs - Disable unnecessary pkgs and its similar to chkconfig
sudo apt-get -f install
sudo apt-get update
sudo apt-get -y install build-essential git
echo "Installing sysv-rc-conf......"
sudo apt-get -y install sysv-rc-conf
sudo sysv-rc-conf --level 12345 dns-clean off
sudo update-rc.d landscape-client disable ---> check
sudo sysv-rc-conf --level 2345 ondemand off
sudo sysv-rc-conf --level 12345 pppd-dns off
sudo sysv-rc-conf --level 2345 rsync off
sudo sysv-rc-conf --level 23456 rsyslog on
sudo sysv-rc-conf --level 06 umountfs off
sudo sysv-rc-conf --level 06 umountroot off
sudo sysv-rc-conf --level 06S urandom off
echo "**********************************************"

#02
#Remove Remote service Daemons & Binaries
#Removing files like .rhosts and .netrc used by remote services like rsh and rlogind, as these services do not use secure connection

echo "Removing files used by unsecured remote services...... "
sudo find . -name ".rhosts" -print >> filerm.txt
sudo find . -name ".netrc" -print >> filerm.txt
if [ -s "filerm.txt" ]
then

        for line in $(cat filerm.txt)
        do
                sudo rm -f $line
        done
else
        echo "no files found...."
fi
sudo rm -f filerm.txt
echo "**********************************************"


#03 
#Password security
echo "Improving the password security....."
login="/etc/login.defs"
sudo chmod 666 $login
sudo sed -i 's/PASS_MAX_DAYS\t99999/PASS_MAX_DAYS\t45/g' $login
sudo sed -i 's/USERGROUPS_ENAB yes/USERGROUPS_ENAB no/' $login
sudo sed "/PASS_MAX_DAYS\t45/i\PASS_MIN_LEN\t8" $login > temp.txt
sudo mv temp.txt $login
sudo chmod 644 $login
echo "password parameters has been changed...."
echo "**********************************************"

#04
#Disable CTRL+ALT+DEL
echo "Disabling the CTRL+ALT+DEL Feature....."
cal_file="/etc/init/control-alt-delete.conf"
sudo sed '/exec shutdown -r now \"Control-Alt-Delete pressed\"/c\#exec shutdown -r now \"Control-Alt-Delete pressed\"' $cal_file>temp.txt
sudo mv temp.txt $cal_file
echo "CTRL+ALT+DEL has been disabled...."
echo "**********************************************"

#05
#To set BASH Timeout 10mins
echo "setting TMOUT for Bash......"
prof_file="/etc/profile"
sudo chmod 666 $prof_file
sudo echo "#Terminal will be closed after TMOUT seconds automatically." >> $prof_file
sudo echo "TMOUT=6000" >> $prof_file
sudo echo "typeset -r TMOUT" >> $prof_file
echo "TMOUT has been set for bash......"
sudo chmod 644 $prof_file
echo "**********************************************"


#06
#Deleting unnecessary system users and groups
