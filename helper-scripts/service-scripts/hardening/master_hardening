sudo aws s3 --region us-east-1 cp s3://Automationscripts/Hardening_Ubuntu/rc.local.template /root/hardening/rc.local.template
rclocal="/etc/rc.local"
rclocalnew="/root/hardening/rc.local.new"
sudo sed '/exit /s/^/#/' /etc/rc.local > $rclocalnew
sudo cat /root/hardening/rc.local.template >> $rclocalnew 
sudo cp $rclocalnew $rclocal
sudo chmod 755 $rclocal
sudo chown root.root $rclocal
echo "**********************************************"

#22
#Update /etc/ssh/sshd_config 
sudo aws s3 --region us-east-1 cp s3://Automationscripts/Hardening_Ubuntu/ubuntu1404_sshd_config /root/hardening/ubuntu1404_sshd_config
sudo cp /root/hardening/ubuntu1404_sshd_config /etc/ssh/sshd_config
sudo service ssh reload

#Update SSH config with custom banner
sudo aws s3 --region us-east-1 cp s3://Automationscripts/Hardening_Ubuntu/banner.txt /root/hardening/banner.txt
echo "Adding Custom Banner....."
ban_file="/etc/banner.txt"
sudo touch $ban_file
sudo chmod 666 $ban_file
content=$(sudo cat /root/hardening/banner.txt)
sudo echo "$content" > $ban_file
ssh_file="/etc/ssh/sshd_config"
tfile="/home/ubuntu/temp.txt"
sudo sed '/#Banner \/etc\/issue.net/c\Banner /etc/banner.txt' $ssh_file > $tfile
sudo mv $tfile $ssh_file
echo "Banner has been added......"
sudo chmod 644 $ban_file
echo "**********************************************"

