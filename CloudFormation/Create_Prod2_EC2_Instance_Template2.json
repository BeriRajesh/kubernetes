{  
   "AWSTemplateFormatVersion":"2010-09-09",
   "Description":"Cloudformation Template",
   "Parameters":{  
      "EnvironmentType":{  
         "Type":"String",
         "Description":"Environment Type where the resources will be deployed",
         "AllowedValues":[  
            "eu-west-dev",
            "eu-west-QA",
            "eu-west-prod",
            "eu-west-mgmt",
            "us-east-dev",
            "us-east-QA",
            "us-east-prod",
            "us-east-mgmt"
         ]
      },
      "ServerType":{
         "Type":"String",
         "Description":"Web or App Server",
         "AllowedValues": [
            "web",
            "app"
         ]
      },
      "Environment":{  
         "Type":"String",
         "Description":"Environment where the resources will be deployed",
         "AllowedValues": [
            "Dev",
            "QA",
            "Prod",
            "Mgmt"
         ]
      },
      "AMI":{  
         "Type":"String",
         "Description":"Use the default ubuntu1404 golden AMI ID or provide another AMI",
         "Default":"ami-e747198d"
      },
      "Application":{
         "Type":"String",
         "Description":"Enter the Application Name in lowercase"
      },
      "IamInstanceRole":{
         "Type":"String",
         "Description":"Provide the new IAM instance profile or use the default one \"automationscripts\" ",
         "Default":"automationscripts"
      },
      "SubnetType":{
         "Type":"String",
         "Description":"Select the Subnet Type",
         "Default":"PrivateSubnetPrimary",
         "AllowedValues":[
            "PrivateSubnetPrimary",
            "PrivateSubnetFailover",
            "PublicSubnetPrimary",
            "PublicSubnetFailover"
         ]
      },
      "EC2KeyPair":{
         "Type":"String",
         "Description":"Select the EC2 Key Pair",
         "AllowedValues":[
            "anlct-dev-key",
            "anlct-prod-key",
            "anlct-qa-key",
            "anlct-mgmt-key",
            "anlcteu-qa-key",
            "anlcteu-prod-key",
            "anlcteu-mgmt-key",
            "anlcteu-dev-key"
         ]
      },
      "InstanceName":{
         "Type":"String",
         "Description":"Provide the Instance Name"
      },
      "EbsVolumeSize":{
         "Type":"String",
         "Default":"8",
         "Description":"Provide the EBS Volume Size or leave the default value"
      },
      "Tagstower":{
         "Type":"String",
         "Description":"Select the value for tower key for tagging",
         "AllowedValues":[
            "unixub",
            "wintel",
            "unixrh-bmc",
            "windb",
            "unixub-mdb",
            "unixrh",
            "unixcent",
            "unixaws",
            "unixub"
         ]
      },
      "InstanceType":{  
         "Description":"EC2 instance type",
         "Type":"String",
         "Default":"m3.medium",
         "AllowedValues": [
           "t1.micro",
           "t2.micro",
           "t2.small",
           "t2.medium",
           "m1.small",
           "m1.medium",
           "m1.large",
           "m1.xlarge",
           "m2.xlarge",
           "m2.2xlarge",
           "m2.4xlarge",
           "m3.medium",
           "m3.large",
           "m3.xlarge",
           "m3.2xlarge",
           "c1.medium",
           "c1.xlarge",
           "c3.large",
           "c3.xlarge",
           "c3.2xlarge",
           "c3.4xlarge",
           "c3.8xlarge",
           "c4.large",
           "c4.xlarge",
           "c4.2xlarge",
           "c4.4xlarge",
           "c4.8xlarge",
           "g2.2xlarge",
           "r3.large",
           "r3.xlarge",
           "r3.2xlarge",
           "r3.4xlarge",
           "r3.8xlarge",
           "i2.xlarge",
           "i2.2xlarge",
           "i2.4xlarge",
           "i2.8xlarge",
           "d2.xlarge",
           "d2.2xlarge",
           "d2.4xlarge",
           "d2.8xlarge",
           "hi1.4xlarge",
           "hs1.8xlarge",
           "cr1.8xlarge",
           "cc2.8xlarge",
           "cg1.4xlarge"
         ],
         "ConstraintDescription":"Must be a valid EC2 instance type."
      }
   },
   "Mappings":{  
      "RegionMap":{  
